  _texts:
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 1
    _text: "......\u3042\u308A\u304C\u3068\u3046"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 1
    _text: "\u98DF\u3079\u7269\u3092\u4E0B\u3055\u3063\u305F\u3001\u304A\u793C\u3067\u3059\n\u308F\u305F\u3057\u304B\u3089\u3082\u4F55\u304B\u3001\u624B\u4F1D\u3048\u308B\u3053\u3068\u306F\u3042\u308A\u307E\u305B\u3093\u304B"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 0
    _text: "......\u305D\u3046\u3060\u306A"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 0
    _text: "\u543E\u8F29\u306F\u3064\u3044\u5148\u307B\u3069\u8A18\u61B6\u3092\u5931\u304F\u3057\u305F\u72B6\u614B\u3067\u76EE\u899A\u3081\u305F\u306E\u3060"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 0
    _text: "\u81EA\u5206\u304C\u4F55\u8005\u3067\u3042\u308B\u304B\u3092\u63A2\u3057\u3001\u5F77\u5FA8\u3063\u3066\u3044\u308B\n\u4F55\u304B\u77E5\u3063\u3066\u3044\u308B\u3053\u3068\u304C\u3042\u308C\u3070\u6559\u3048\u3066\u307B\u3057\u3044"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 1
    _text: "......\u8A18\u61B6\u3092"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 1
    _text: "......\u305D\u3046\u3067\u3059\u304B\n\u3048\u3048\u3001\u308F\u304B\u308A\u307E\u3057\u305F"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 1
    _text: "\u3042\u306A\u305F\u306E\u8A18\u61B6\u3092\u601D\u3044\u51FA\u3055\u305B\u308B\u60C5\u5831\u306F\u751F\u618E\u3068\u6301\u3061\u5408\u308F\u305B\u3066\u3044\u307E\u305B\u3093\u304C\u3001\u559C\u3093\u3067\u5354\u529B\u3057\u307E\u3057\u3087\u3046\n\u3053\u306E\u9996\u8F2A\u306B\u8A93\u3063\u3066"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 1
    _text: "......\u3042\u3089\uFF1F"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 0
    _text: "\u3069\u3046\u3057\u305F\uFF1F"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 1
    _text: "\u9996\u8F2A\u3001\u308F\u305F\u3057\u306E\u5927\u5207\u306A\u9996\u8F2A\u304C\u3001\u7121\u3044\u3001\u7121\u3044\u3093\u3067\u3059"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 1
    _text: "\u305D\u3001\u305D\u3093\u306A\n\u3069\u3053\u3067\u3001\u3044\u3064\u3001\u843D\u3068\u3057\u3066\u3057\u307E\u3063\u305F\u306E\u3067\u3057\u3087\u3046\u304B!?"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 0
    _text: "......\u4ED5\u65B9\u306A\u3044\u3001\u305D\u3093\u306A\u306B\u5927\u4E8B\u306A\u9996\u8F2A\u306A\u3089\u543E\u8F29\u3082\u63A2\u3057\u3066\u3084\u308D\u3046\n\u3069\u3093\u306A\u9996\u8F2A\u306A\u3093\u3060"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 1
    _text: "\u300E\u300F\u8272\u306E\u9996\u8F2A\u3067\u3059"
  - _leftTalker: 0
    _rightTalker: 1
    _talker: 0
    _text: "\u308F\u304B\u3063\u305F\n\u5C11\u3057\u5F85\u3063\u3066\u3044\u308B\u3068\u3044\u3044"
